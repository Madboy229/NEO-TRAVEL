# LLM — Vercel AI Gateway (clé "vck_*" fournie par l'école — accès multi-provider)
VERCEL_AI_GATEWAY_KEY=
VERCEL_AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1

# Optionnel : clé Gemini personnelle (Google AI Studio) — fallback dev local
GEMINI_API_KEY=

# Airtable (https://airtable.com/create/tokens)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Brevo (https://app.brevo.com/settings/keys/api) — retenu pour envoi libre sans domaine vérifié
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=Neotravel

# Resend (alternative, https://resend.com/api-keys) — non retenu, voir docs/flow-email-consentement.md
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# n8n (webhook URL exposée par le workflow)
N8N_WEBHOOK_URL=
